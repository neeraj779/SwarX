{
  "name": "service",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "NODE_NO_WARNINGS=1 NODE_ENV=development concurrently \"node esbuild.config.js --watch\" \"nodemon --watch dist --ext js --ignore src/**/* dist/index.js\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "auth:schema:generate": "npx @better-auth/cli generate --output src/db/auth.schema.ts --y",
    "db:push": "npx drizzle-kit push",
    "db:pull": "npx drizzle-kit pull",
    "db:apply": "npm run db:generate && read -p 'Are you sure you want to run migrations? (y/N) ' confirm && [[ $confirm == [yY] || $confirm == [yY][eE][sS] ]] && npm run db:migrate",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:studio": "npx drizzle-kit studio --port 3003 --verbose"
  },
  "author": "Neeraj",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@libsql/client": "^0.15.0",
    "better-auth": "^1.2.4",
    "better-sqlite3": "^11.9.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.1",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "node-forge": "^1.3.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "swagger-jsdoc": "^6.2.8",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node-forge": "^1.3.11",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.5",
    "esbuild": "0.25.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^16.0.0",
    "nodemon": "^3.1.9",
    "prettier": "3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  }
}
